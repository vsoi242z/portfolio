<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Otsoua-Ibata Van-Sorel — Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --card: #16161f;
    --accent: #00e5ff;
    --accent2: #7c3aed;
    --accent3: #f59e0b;
    --text: #f0f0f5;
    --muted: #6b6b80;
    --border: rgba(255,255,255,0.07);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    overflow-x: hidden;
    cursor: none;
  }

  .cursor {
    width: 10px; height: 10px;
    background: var(--accent); border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    transition: transform 0.15s ease, background 0.2s;
    transform: translate(-50%, -50%);
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1px solid var(--accent); border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9998;
    transition: transform 0.4s ease, border-color 0.3s;
    transform: translate(-50%, -50%); opacity: 0.5;
  }

  body::before {
    content: ''; position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 0; opacity: 0.4;
  }

  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 20px 48px; display: flex; justify-content: space-between; align-items: center;
    backdrop-filter: blur(20px); border-bottom: 1px solid var(--border);
    background: rgba(10,10,15,0.7);
  }
  .nav-logo {
    font-family: 'Syne', sans-serif; font-weight: 800;
    font-size: 1.1rem; letter-spacing: 0.05em;
    color: var(--text); text-decoration: none;
  }
  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    text-decoration: none; color: var(--muted);
    font-size: 0.75rem; letter-spacing: 0.12em;
    text-transform: uppercase; transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }

  .hero {
    min-height: 100vh; display: flex; align-items: center;
    padding: 120px 48px 80px; position: relative; overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 70% 50%, rgba(0,229,255,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 30% 80%, rgba(124,58,237,0.08) 0%, transparent 60%);
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
  }
  .hero-content { position: relative; z-index: 1; max-width: 900px; }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(0,229,255,0.08); border: 1px solid rgba(0,229,255,0.2);
    color: var(--accent); font-size: 0.7rem; letter-spacing: 0.15em;
    text-transform: uppercase; padding: 6px 16px; border-radius: 100px;
    margin-bottom: 28px; animation: fadeUp 0.6s ease both;
  }
  .hero-tag::before {
    content: ''; width: 6px; height: 6px;
    background: var(--accent); border-radius: 50%; animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.8)} }

  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3rem, 8vw, 7rem); font-weight: 800;
    line-height: 0.95; letter-spacing: -0.03em;
    animation: fadeUp 0.6s 0.1s ease both;
  }
  .hero h1 .line2 { display: block; color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.25); }
  .hero h1 .accent { color: var(--accent); }
  .hero-sub {
    margin-top: 28px; font-size: 0.85rem; color: var(--muted);
    max-width: 500px; line-height: 1.8; animation: fadeUp 0.6s 0.2s ease both;
  }
  .hero-cta { margin-top: 40px; display: flex; gap: 16px; flex-wrap: wrap; animation: fadeUp 0.6s 0.3s ease both; }
  .btn-primary {
    background: var(--accent); color: #000; padding: 14px 28px;
    border-radius: 6px; text-decoration: none; font-size: 0.75rem;
    font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    transition: transform 0.2s, box-shadow 0.2s; font-family: 'DM Mono', monospace;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,229,255,0.3); }
  .btn-outline {
    border: 1px solid var(--border); color: var(--text); padding: 14px 28px;
    border-radius: 6px; text-decoration: none; font-size: 0.75rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s; font-family: 'DM Mono', monospace;
  }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

  .hero-stats { margin-top: 64px; display: flex; gap: 48px; animation: fadeUp 0.6s 0.4s ease both; }
  .stat-num { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 700; color: var(--accent); }
  .stat-label { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4px; }

  @keyframes fadeUp { from { opacity:0; transform: translateY(24px); } to { opacity:1; transform: translateY(0); } }

  section { padding: 96px 48px; position: relative; }
  .section-header { display: flex; align-items: center; gap: 16px; margin-bottom: 64px; }
  .section-num { font-size: 0.65rem; color: var(--accent); letter-spacing: 0.2em; text-transform: uppercase; }
  .section-title { font-family: 'Syne', sans-serif; font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 700; letter-spacing: -0.02em; }
  .section-line { flex: 1; height: 1px; background: var(--border); margin-left: 24px; }

  #about { background: var(--surface); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .about-text p { font-size: 0.85rem; color: var(--muted); line-height: 1.9; margin-bottom: 16px; }
  .about-text p strong { color: var(--text); }
  .about-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 32px; }
  .about-card h3 { font-family: 'Syne', sans-serif; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 20px; }
  .contact-item { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 0.78rem; color: var(--muted); }
  .contact-item:last-child { border-bottom: none; }
  .contact-icon { font-size: 1rem; }
  .contact-item a { color: var(--accent); text-decoration: none; }
  .contact-item a:hover { text-decoration: underline; }

  .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  .skill-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 12px;
    padding: 28px; transition: border-color 0.3s, transform 0.3s; position: relative; overflow: hidden;
  }
  .skill-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    transform: scaleX(0); transform-origin: left; transition: transform 0.3s;
  }
  .skill-card:hover { border-color: rgba(0,229,255,0.2); transform: translateY(-4px); }
  .skill-card:hover::before { transform: scaleX(1); }
  .skill-card-icon { font-size: 1.6rem; margin-bottom: 16px; }
  .skill-card h3 { font-family: 'Syne', sans-serif; font-size: 0.9rem; font-weight: 700; margin-bottom: 12px; color: var(--text); }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
  .skill-tag { background: rgba(0,229,255,0.07); border: 1px solid rgba(0,229,255,0.15); color: var(--accent); font-size: 0.65rem; padding: 4px 10px; border-radius: 4px; letter-spacing: 0.08em; text-transform: uppercase; }
  .skill-tag.purple { background: rgba(124,58,237,0.1); border-color: rgba(124,58,237,0.25); color: #a78bfa; }
  .skill-tag.amber { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.25); color: var(--accent3); }

  #experience { background: var(--surface); }
  .timeline { position: relative; padding-left: 32px; }
  .timeline::before {
    content: ''; position: absolute; left: 0; top: 8px; bottom: 8px;
    width: 1px; background: linear-gradient(to bottom, var(--accent), var(--accent2), transparent);
  }
  .timeline-item { position: relative; margin-bottom: 56px; }
  .timeline-item::before {
    content: ''; position: absolute; left: -36px; top: 8px;
    width: 8px; height: 8px; background: var(--accent);
    border-radius: 50%; box-shadow: 0 0 0 3px rgba(0,229,255,0.15);
  }
  .timeline-meta { display: flex; align-items: center; gap: 16px; margin-bottom: 12px; flex-wrap: wrap; }
  .timeline-date { font-size: 0.65rem; color: var(--accent); letter-spacing: 0.15em; text-transform: uppercase; background: rgba(0,229,255,0.08); padding: 4px 10px; border-radius: 4px; border: 1px solid rgba(0,229,255,0.15); }
  .timeline-location { font-size: 0.7rem; color: var(--muted); }
  .timeline-item h3 { font-family: 'Syne', sans-serif; font-size: 1.2rem; font-weight: 700; margin-bottom: 4px; color: var(--text); }
  .timeline-item h4 { font-size: 0.75rem; font-weight: 400; margin-bottom: 16px; color: #a78bfa; }
  .timeline-list { list-style: none; padding: 0; }
  .timeline-list li { font-size: 0.8rem; color: var(--muted); line-height: 1.7; padding: 6px 0; border-bottom: 1px solid var(--border); display: flex; gap: 10px; align-items: baseline; }
  .timeline-list li:last-child { border-bottom: none; }
  .timeline-list li::before { content: '→'; color: var(--accent); flex-shrink: 0; }

  .edu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; }
  .edu-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 32px; transition: border-color 0.3s, transform 0.3s; position: relative; overflow: hidden; }
  .edu-card:hover { border-color: rgba(124,58,237,0.4); transform: translateY(-4px); }
  .edu-card-accent { position: absolute; top: 0; right: 0; width: 120px; height: 120px; border-radius: 50%; background: radial-gradient(circle, rgba(124,58,237,0.15) 0%, transparent 70%); transform: translate(30%, -30%); }
  .edu-year { font-size: 0.65rem; color: #a78bfa; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 12px; }
  .edu-card h3 { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
  .edu-card h4 { font-size: 0.75rem; color: var(--accent); margin-bottom: 12px; }
  .edu-card p { font-size: 0.75rem; color: var(--muted); line-height: 1.7; }
  .edu-school { margin-top: 16px; font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }

  #projects { background: var(--surface); }
  .project-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 40px; display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center; transition: border-color 0.3s; }
  .project-card:hover { border-color: rgba(245,158,11,0.3); }
  .project-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25); color: var(--accent3); font-size: 0.65rem; padding: 4px 12px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; }
  .project-card h3 { font-family: 'Syne', sans-serif; font-size: 1.6rem; font-weight: 700; margin-bottom: 12px; }
  .project-card p { font-size: 0.82rem; color: var(--muted); line-height: 1.8; max-width: 600px; }
  .project-tags { display: flex; gap: 8px; margin-top: 20px; flex-wrap: wrap; }
  .project-flag { font-size: 3rem; opacity: 0.8; }

  /* CLINIQUE PASTEUR - detailed project */
  .project-big {
    background: var(--card); border: 1px solid var(--border); border-radius: 12px;
    padding: 40px; margin-top: 24px; transition: border-color 0.3s;
    position: relative; overflow: hidden;
  }
  .project-big::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--accent), #a78bfa, transparent);
  }
  .project-big:hover { border-color: rgba(0,229,255,0.2); }
  .project-big-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 24px; margin-bottom: 28px; flex-wrap: wrap;
  }
  .project-big h3 { font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 700; margin-bottom: 6px; }
  .project-big-sub { font-size: 0.75rem; color: #a78bfa; margin-bottom: 4px; }
  .project-big-context { font-size: 0.8rem; color: var(--muted); line-height: 1.8; margin-bottom: 28px; }
  .project-big-context strong { color: var(--text); }
  .missions-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-bottom: 28px; }
  .mission-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
    padding: 20px; transition: border-color 0.2s;
  }
  .mission-card:hover { border-color: rgba(0,229,255,0.2); }
  .mission-num { font-size: 0.6rem; color: var(--accent); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 8px; }
  .mission-card h4 { font-family: 'Syne', sans-serif; font-size: 0.85rem; font-weight: 700; margin-bottom: 10px; color: var(--text); }
  .mission-card ul { list-style: none; padding: 0; }
  .mission-card ul li { font-size: 0.72rem; color: var(--muted); padding: 3px 0; display: flex; gap: 8px; align-items: baseline; line-height: 1.5; }
  .mission-card ul li::before { content: '·'; color: var(--accent); flex-shrink: 0; }

  .lang-section { display: flex; gap: 24px; margin-top: 48px; flex-wrap: wrap; }
  .lang-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 28px 36px; text-align: center; min-width: 160px; }
  .lang-flag { font-size: 2.5rem; margin-bottom: 10px; }
  .lang-name { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
  .lang-level { font-size: 0.7rem; color: var(--accent); }

  footer { background: var(--card); border-top: 1px solid var(--border); padding: 48px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 24px; }
  .footer-name { font-family: 'Syne', sans-serif; font-size: 1.4rem; font-weight: 800; }
  .footer-name span { color: var(--accent); }
  .footer-links { display: flex; gap: 24px; }
  .footer-links a { color: var(--muted); text-decoration: none; font-size: 0.75rem; transition: color 0.2s; }
  .footer-links a:hover { color: var(--accent); }
  .footer-copy { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; }

  .reveal { opacity: 0; transform: translateY(32px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* VEILLE */
  #veille { background: var(--surface); }
  .veille-intro {
    font-size: 0.85rem; color: var(--muted); line-height: 1.9;
    max-width: 700px; margin-bottom: 56px;
  }
  .veille-intro strong { color: var(--text); }
  .veille-grid { display: flex; flex-direction: column; gap: 32px; }
  .veille-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 12px;
    padding: 36px 40px; display: grid; grid-template-columns: auto 1fr;
    gap: 40px; align-items: start; transition: border-color 0.3s, transform 0.2s;
    position: relative; overflow: hidden;
  }
  .veille-card::after {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: var(--accent); transform: scaleY(0);
    transform-origin: top; transition: transform 0.3s;
  }
  .veille-card:hover { border-color: rgba(0,229,255,0.2); transform: translateX(4px); }
  .veille-card:hover::after { transform: scaleY(1); }
  .veille-card:nth-child(2)::after { background: #a78bfa; }
  .veille-card:nth-child(3)::after { background: var(--accent3); }
  .veille-num {
    font-family: 'Syne', sans-serif; font-size: 3rem; font-weight: 800;
    color: var(--border); line-height: 1; user-select: none;
    min-width: 60px; text-align: right;
  }
  .veille-source {
    font-size: 0.65rem; color: var(--muted); letter-spacing: 0.12em;
    text-transform: uppercase; margin-bottom: 10px;
    display: flex; align-items: center; gap: 10px;
  }
  .veille-source::before { content: ''; width: 20px; height: 1px; background: var(--muted); display: inline-block; }
  .veille-card h3 {
    font-family: 'Syne', sans-serif; font-size: 1.15rem; font-weight: 700;
    margin-bottom: 14px; color: var(--text); line-height: 1.3;
  }
  .veille-card p {
    font-size: 0.8rem; color: var(--muted); line-height: 1.85; margin-bottom: 10px;
  }
  .veille-card p strong { color: var(--text); }
  .veille-insight {
    margin-top: 18px; padding: 14px 18px;
    background: rgba(0,229,255,0.05); border-left: 2px solid var(--accent);
    border-radius: 0 6px 6px 0; font-size: 0.75rem; color: var(--muted); line-height: 1.7;
  }
  .veille-card:nth-child(2) .veille-insight { background: rgba(124,58,237,0.05); border-left-color: #a78bfa; }
  .veille-card:nth-child(3) .veille-insight { background: rgba(245,158,11,0.05); border-left-color: var(--accent3); }
  .veille-insight strong { color: var(--text); }

  @media(max-width: 768px) {
    .veille-card { grid-template-columns: 1fr; gap: 16px; padding: 24px; }
    .veille-num { font-size: 2rem; text-align: left; }
  }

  /* SPORT */
  #sport { background: var(--surface); }
  .sport-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; margin-bottom: 56px; }
  .sport-club-header { display: flex; align-items: center; gap: 16px; margin-bottom: 12px; }
  .sport-logo-slot {
    width: 56px; height: 56px; border-radius: 10px;
    border: 2px dashed rgba(0,229,255,0.3);
    background: rgba(0,229,255,0.05);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; flex-shrink: 0; cursor: pointer;
    transition: border-color 0.2s;
  }
  .sport-logo-slot:hover { border-color: var(--accent); }
  .sport-logo-slot img { width: 100%; height: 100%; object-fit: contain; }
  .sport-logo-slot .placeholder-text { font-size: 0.5rem; color: var(--muted); text-align: center; line-height: 1.3; padding: 4px; }
  .sport-division { font-size: 0.65rem; color: var(--accent); letter-spacing: 0.2em; text-transform: uppercase; }
  .sport-identity h3 { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; line-height: 1.1; margin-bottom: 8px; }
  .sport-identity h3 span { color: var(--accent); }
  .sport-poste { font-size: 0.8rem; color: #a78bfa; margin-bottom: 20px; }
  .sport-story { font-size: 0.8rem; color: var(--muted); line-height: 1.9; }
  .sport-story strong { color: var(--text); }
  .sport-stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .sport-stat { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 20px; text-align: center; transition: border-color 0.2s, transform 0.2s; }
  .sport-stat:hover { border-color: rgba(0,229,255,0.3); transform: translateY(-3px); }
  .sport-stat-num { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; color: var(--accent); line-height: 1; }
  .sport-stat-num.purple { color: #a78bfa; }
  .sport-stat-num.amber { color: var(--accent3); }
  .sport-stat-label { font-size: 0.62rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 6px; }
  .sport-matches h4, .sport-objectifs h4 { font-family: 'Syne', sans-serif; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 20px; }
  .sport-objectifs h4 { color: #a78bfa; }
  .match-table { width: 100%; border-collapse: collapse; }
  .match-table th { font-size: 0.6rem; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border); }
  .match-table td { font-size: 0.75rem; color: var(--muted); padding: 12px; border-bottom: 1px solid var(--border); vertical-align: middle; }
  .match-table tr:last-child td { border-bottom: none; }
  .match-table tr:hover td { background: rgba(255,255,255,0.02); }
  .match-result { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.85rem; }
  .match-result.win { color: #22c55e; }
